# LINE Channel Configuration (for Cloud Functions)
# Get these from LINE Developers Console: https://developers.line.biz/
LINE_CHANNEL_ID=your-channel-id
LINE_CHANNEL_SECRET=your-channel-secret

# HMAC secret for Cloud Tasks request signing (any long random string).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# When unset, task signature verification is skipped (backward compatible).
POKER_TASKS_SECRET=
