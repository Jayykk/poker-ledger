rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check authentication
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function to check if the current user is an admin
    // Admin status is stored as a document existence check in the 'admins' collection.
    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // User documents
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
      
      // User's friends sub-collection
      match /friends/{friendId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // ============================================
    // Admin registry – only Cloud Functions / manual setup writes here.
    // Authenticated users can check their own admin status.
    // ============================================
    match /admins/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // managed server-side only
    }
    
    // Game documents (existing ledger games)
    match /games/{gameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        (request.auth.uid == resource.data.hostUid || 
         isAdmin() ||
         request.auth.uid in resource.data.players[].uid);
      allow delete: if request.auth.uid == resource.data.hostUid || isAdmin();

      // Config version history (written by frontend after each config change)
      match /configVersions/{versionId} {
        allow read: if isAuthenticated() &&
          (resource == null || request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.hostUid || isAdmin());
        allow create: if isAuthenticated() &&
          (request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.hostUid || isAdmin());
        allow update, delete: if false;
      }
      
      // Game chat sub-collection
      match /chat/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
    }
    
    // ============================================
    // 德州撲克遊戲規則 (Texas Hold'em Poker Rules)
    // ============================================
    
    // Poker game rooms
    match /pokerGames/{gameId} {
      // Anyone authenticated can read game state
      allow read: if isAuthenticated();
      
      // Anyone authenticated can create a game
      allow create: if isAuthenticated() &&
        request.resource.data.meta.createdBy == request.auth.uid;
      
      // Only authenticated players can update the game
      // Detailed validation should be done in Cloud Functions
      allow update: if isAuthenticated();
      
      // Only the creator can delete the game
      allow delete: if isAuthenticated() && 
        resource.data.meta.createdBy == request.auth.uid;
      
      // Config version history for cash table admin edits
      // Host (meta.createdBy) or admin can create versions; no one can alter history.
      match /configVersions/{versionId} {
        allow read: if isAuthenticated() &&
          (resource == null ||
           request.auth.uid == get(/databases/$(database)/documents/pokerGames/$(gameId)).data.meta.createdBy ||
           isAdmin());
        allow create: if isAuthenticated() &&
          (request.auth.uid == get(/databases/$(database)/documents/pokerGames/$(gameId)).data.meta.createdBy ||
           isAdmin());
        allow update, delete: if false;
      }
      
      // Hand history sub-collection
      // Records of each hand played
      match /hands/{handId} {
        // Anyone in the game can read hand history
        allow read: if isAuthenticated();
        
        // Only Cloud Functions can write hand history
        // This ensures game integrity
        allow write: if false;
      }
      
      // Private hole cards sub-collection
      // Each player's private cards
      match /private/{userId} {
        // Only the player can read their own hole cards
        allow read: if isOwner(userId);
        
        // Only Cloud Functions can write hole cards
        // This prevents cheating
        allow write: if false;
      }
    }
    
    // ============================================
    // Transaction Audit Trail (Buy-in records)
    // ============================================
    match /transactions/{txId} {
      // Authenticated users can read transactions for games they're in
      allow read: if isAuthenticated();
      
      // Allow authenticated users to create transactions
      // Also allow Cloud Functions via admin SDK (bypasses rules)
      allow create: if isAuthenticated();
      
      // Only allow updates to mark transactions as undone
      allow update: if isAuthenticated()
        && request.resource.data.status == 'undone'
        && resource.data.status == 'active';
    }
    
    // ============================================
    // Additional collections can be added here
    // ============================================

    // ============================================
    // Tournament Sessions (clock state)
    // ============================================
    match /tournamentSessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.hostUid == request.auth.uid;
      // Host can always update; any authenticated user can update if dealer mode is on;
      // admins can update any session.
      allow update: if isAuthenticated()
        && (resource.data.hostUid == request.auth.uid
            || resource.data.dealerModeEnabled == true
            || isAdmin());
      allow delete: if isAuthenticated()
        && (resource.data.hostUid == request.auth.uid || isAdmin());

      // Config version history
      match /configVersions/{versionId} {
        allow read: if isAuthenticated() &&
          (resource == null || request.auth.uid == get(/databases/$(database)/documents/tournamentSessions/$(sessionId)).data.hostUid || isAdmin());
        allow create: if isAuthenticated() &&
          (request.auth.uid == get(/databases/$(database)/documents/tournamentSessions/$(sessionId)).data.hostUid || isAdmin());
        allow update, delete: if false;
      }
    }

    // ============================================
    // User Tournament Presets (custom structures)
    // ============================================
    match /users/{userId}/tournamentPresets/{presetId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ============================================
    // Time Bank Sessions
    // ============================================
    match /timeBankSessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.hostUid == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.hostUid == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.hostUid == request.auth.uid;
    }
  }
}

