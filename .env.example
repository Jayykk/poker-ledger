# Firebase Configuration
# These values are safe to expose in client-side code as they identify the Firebase project
# Actual security is controlled by Firestore security rules

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# LINE LIFF Configuration
# Create a LIFF app in LINE Developers Console (https://developers.line.biz/)
# Channel type: LINE Login → LIFF tab → Add LIFF app
# Size: Full; Endpoint URL: your deployed app URL (e.g. https://your-project.web.app)
VITE_LIFF_ID=your-liff-id
